{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=ClinicSaasDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Database": {
    "UseInMemory": true
  },
  "Jwt": {
    "Issuer": "ClinicSaas",
